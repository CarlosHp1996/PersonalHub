# ==============================================================================
# PERSONAL HUB - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to '.env' at the repository root and fill in your real values.
# NEVER commit the '.env' file to git version control.

# ------------------------------------------------------------------------------
# 1. PostgreSQL Database Configuration
# ------------------------------------------------------------------------------
POSTGRES_DB=assistant_db
POSTGRES_USER=assistant
POSTGRES_PASSWORD=your_secure_password_here
# Connection string used by EF Core in .NET (runs inside Docker container network)
POSTGRES_CONNECTION=Host=postgres;Port=5432;Database=assistant_db;Username=assistant;Password=your_secure_password_here

# ------------------------------------------------------------------------------
# 2. Redis Caching & Event Bus Configuration
# ------------------------------------------------------------------------------
# Endpoint for Redis inside the Docker Compose network
REDIS_CONNECTION=redis:6379

# ------------------------------------------------------------------------------
# 3. RabbitMQ Message Broker Configuration
# ------------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ------------------------------------------------------------------------------
# 4. Telegram Bot API Configuration
# ------------------------------------------------------------------------------
# Obtained via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram Chat ID (can be fetched using getUpdates API)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ------------------------------------------------------------------------------
# 5. External Financial & Weather APIs
# ------------------------------------------------------------------------------
# Binance WebSocket and REST base URL for crypto prices
BINANCE_BASE_URL=https://api.binance.com
# AwesomeAPI base URL for BRL currencies and metals
AWESOME_API_BASE_URL=https://economia.awesomeapi.com.br
# Alpha Vantage developer key for global stock market metrics
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# Open-Meteo REST URL for weather forecasting
OPEN_METEO_BASE_URL=https://api.open-meteo.com
# OpenWeatherMap key for current conditions and alerts
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here
# GNews API key for PT-BR localized headlines
GNEWS_API_KEY=your_gnews_key_here
# NewsAPI key for global financial headlines
NEWSAPI_KEY=your_newsapi_key_here
# CoinGecko REST URL for crypto historical aggregates
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ------------------------------------------------------------------------------
# 6. Polymarket CLOB API Credentials
# ------------------------------------------------------------------------------
# Polymarket Central Limit Order Book API credentials
POLYMARKET_API_KEY=your_polymarket_api_key_uuid_here
POLYMARKET_API_SECRET=your_polymarket_api_secret_here
POLYMARKET_API_PASSPHRASE=your_polymarket_api_passphrase_here
# Your Polymarket Polygon wallet address
POLYMARKET_WALLET_ADDRESS=your_wallet_address_0x_here
# WebSocket user events channel for trades and order logs
POLYMARKET_WSS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
# REST endpoint for market specs and positions
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com

# ------------------------------------------------------------------------------
# 7. Internal Microservice Authentication (Service-to-Service)
# ------------------------------------------------------------------------------
# .NET base URL (runs inside Docker container network, consumed by Python bot)
API_BASE_URL=http://api:5000
# Symmetric JWT key shared between .NET Minimal API and Python HttpClient
API_SECRET_KEY=internal_secret_for_service_auth_jwt_key
